. foreach v in emp inv ppi sal {
  2.     foreach s in niv d1 ds {
  3.         local p = scalar(adfp_`v'_`s')
  4.         if      `p' < 0.01  local sig_`v'_`s' "***"
  5.         else if `p' < 0.05  local sig_`v'_`s' "**"
  6.         else if `p' < 0.10  local sig_`v'_`s' "*"
  7.         else                 local sig_`v'_`s' ""
  8.     }
  9. }

. 
