. *===========================================================================
. **# 12. TEST DE DIEBOLD-MARIANO (sobre errores B-O)
. *===========================================================================
. 
. qui count if test==1

. local T_test   = r(N)

. local lags_hac = floor(`T_test'^(1/3))

. di _newline "Observaciones test: `T_test'   Lags HAC: `lags_hac'"

Observaciones test: 36   Lags HAC: 3

. 
. gen dm_A = e2_base - e2_ctrl
(273 missing values generated)

. gen dm_B = e2_base - e2_comp
(273 missing values generated)

. gen dm_C = e2_ctrl - e2_comp
(273 missing values generated)

. 
. label var dm_A "DM: base vs +controles (B-O)"

. label var dm_B "DM: base vs completo (B-O)"

. label var dm_C "DM: +controles vs completo (B-O)"

. 
. foreach c in A B C {
  2.     qui summarize dm_`c' if test==1
  3.     scalar dm_`c'_mean = r(mean)
  4.     newey dm_`c' if test==1, lag(`lags_hac')
  5.     scalar dm_`c'_stat = _b[_cons] / _se[_cons]
  6.     scalar dm_`c'_se   = _se[_cons]
  7.     test _cons
  8.     scalar dm_`c'_pval = r(p)
  9.     local p = scalar(dm_`c'_pval)
 10.     if      `p' < 0.01  local sig_`c' "***"
 11.     else if `p' < 0.05  local sig_`c' "**"
 12.     else if `p' < 0.10  local sig_`c' "*"
 13.     else                 local sig_`c' ""
 14.     if      `p' < 0.05 & scalar(dm_`c'_mean) < 0  local concl_`c' "Modelo 1 mejor"
 15.     else if `p' < 0.05 & scalar(dm_`c'_mean) > 0  local concl_`c' "Modelo 2 mejor"
 16.     else                                            local concl_`c' "Sin diferencia sig."
 17. }

