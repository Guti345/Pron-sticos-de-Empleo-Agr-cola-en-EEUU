. foreach v in emp inv ppi sal {
  2.     if "`v'" == "emp" local vname "ln_emp_agr"
  3.     if "`v'" == "inv" local vname "ln_inv_manuf"
  4.     if "`v'" == "ppi" local vname "ln_ppi_farm"
  5.     if "`v'" == "sal" local vname "ln_salario_min"
  6. 
.     dfuller `vname', lags(12) trend
  7.     scalar adf_`v'_niv  = r(Zt)
  8.     scalar adfp_`v'_niv = r(p)
  9. 
.     dfuller D.`vname', lags(12) trend
 10.     scalar adf_`v'_d1  = r(Zt)
 11.     scalar adfp_`v'_d1 = r(p)
 12. 
.     dfuller DS12.`vname', lags(12) trend
 13.     scalar adf_`v'_ds  = r(Zt)
 14.     scalar adfp_`v'_ds = r(p)
 15. }

